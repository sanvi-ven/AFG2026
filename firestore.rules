rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public (unauthenticated) reads on specific collections
    match /client_signups/{document=**} {
      // Allow unauthenticated signup creation
      allow create: if request.auth == null && validateSignupData();
      // Allow authenticated users to read their own profile
      allow read, update, delete: if request.auth != null && resource.data.email == request.auth.token.email;
      // Allow reads by anyone (for autocomplete)
      allow read: if request.auth == null;
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function validateSignupData() {
  let data = request.resource.data;
  return data.size() > 0 &&
         data.email is string &&
         data.firstName is string &&
         data.lastName is string &&
         data.phoneNumber is string &&
         data.address is string;
}
